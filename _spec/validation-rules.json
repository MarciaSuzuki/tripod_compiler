      "pericope_classification": {
        "type": "object",
        "additionalProperties": false,
        "required": ["genre_group", "genre", "register", "register_overrides"],
        "properties": {
          "genre_group": {
            "enum": ["NARRATIVE", "POETIC_SUNG", "INSTRUCTIONAL_REGULATORY", "ORAL_DISCOURSE"]
          },
          "genre": { "$ref": "#/$defs/genre_value" },
          "register": { "$ref": "#/$defs/register_value" },
          "register_overrides": {
            "type": "object",
            "additionalProperties": false,
            "required": ["scene_level", "moment_level"],
            "properties": {
              "_note": { "type": "string" },
              "scene_level": {
                "anyOf": [
                  { "type": "null" },
                  { "type": "array", "items": { "$ref": "#/$defs/register_override_entry" } }
                ]
              },
              "moment_level": {
                "anyOf": [
                  { "type": "null" },
                  { "type": "array", "items": { "$ref": "#/$defs/register_override_entry" } }
                ]
              }
            }
          }
        },
        "allOf": [
          {
            "_comment": "SC-0046 (genre-aware pericope register, Marcia's A-ruling on the J03 finding): a NARRATIVE pericope keeps the narrator constant — its pericope-level register MUST be INFORMAL_CASUAL (shifts live in register_overrides). A non-narrative pericope (the J03 psalm: no narrator voice) carries its true register from the closed seven.",
            "if": {
              "properties": { "genre_group": { "const": "NARRATIVE" } },
              "required": ["genre_group"]
            },
            "then": {
              "properties": { "register": { "const": "INFORMAL_CASUAL" } }
            }
          }
        ]
      },

      "register_override_entry": {
        "type": "object",
        "additionalProperties": false,
        "description": "A scene- or moment-level override. Carries a social-register override (override_value, one of the 7 REGISTER values) and/or a narrative-framing/voice override (framing_override, from NARRATIVE_FRAMING). At least one of the two must be present (SC-0001).",
        "anyOf": [
          { "required": ["override_value"] },
          { "required": ["framing_override"] }
        ],
        "properties": {
          "verse": { "type": "string", "minLength": 1 },
          "scene_id": { "$ref": "#/$defs/scene_id" },
          "override_value": { "$ref": "#/$defs/register_value" },
          "framing_override": { "$ref": "#/$defs/narrative_framing_value" },
          "genre_override": {
            "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/genre_value" }]
          },
          "genre_group_override": {
            "anyOf": [
              { "type": "null" },
              { "enum": ["NARRATIVE", "POETIC_SUNG", "INSTRUCTIONAL_REGULATORY", "ORAL_DISCOURSE"] }
            ]
          }
        }
      },

      "l3_component_ref": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prop_id", "slot", "list_position"],
        "description": "SC-0030: a path reference into a Level-3 proposition component (event_specific_slots[slot] item with that list_position). The engine resolves it; a dangling ref blocks.",
        "properties": {
