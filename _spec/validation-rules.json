      "fidelity_layer": {
        "type": "object",
        "additionalProperties": false,
        "description": "SC-0030 (Level-3 purity): the parallel fidelity/conditioning layer, sibling to level_3_propositions. Keeps Level 3 a pure supervision target (inventory only) — the fidelity FLAGS live here and reference the L3 content by path. NO free-text 'meaning' (the rationale lives in the governance/SC docs). The SC-0027 two-axis fidelity MODEL is unchanged; only its placement moved out of the L3 content objects. The engine resolves every ref (dangling ref blocks) and every element.group (the dangling-group-id check).",
        "properties": {
          "elements": { "type": "array", "items": { "$ref": "#/$defs/fidelity_element" } },
          "groups": { "type": "array", "items": { "$ref": "#/$defs/fidelity_group" } },
