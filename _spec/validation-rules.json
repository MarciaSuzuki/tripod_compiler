        "CLAN_IDENTITY_OF_HOUSEHOLD",
        "DECEASED_HOUSEHOLD_HEAD",
        "WIDOW_REMAINING_AS_RESIDUE",
        "SURVIVING_SON_WITH_MOTHER",
        "SON_TAKING_FOREIGN_WIFE",
        "SOURCE_POOL_FROM_WHICH_WIVES_ARE_TAKEN",
        "FOREIGN_BRIDE_INCORPORATED_INTO_HOUSEHOLD",
        "MATRIARCH_OF_EXTENDED_HOUSEHOLD",
        "DECEASED_SON",
        "DOUBLY_BEREAVED_WIDOW_REDUCED_TO_RESIDUE",
        "PREVIOUSLY_DECEASED_HUSBAND_INVOKED_IN_CUMULATIVE_LOSS",
        "FOREIGN_DAUGHTER_IN_LAW_NOW_ALSO_BEREAVED"
      ],
      "role_in_scene_examples_place": [
        "LAND_AFFLICTED_BY_FAMINE",
