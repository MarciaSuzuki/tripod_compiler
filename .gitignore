# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Zip / archive exports (skeleton was shipped as a zip; don't re-commit archives)
*.zip

# Logs & env
*.log
.env
.env.*

# OS / editor cruft
.DS_Store
.idea/
.vscode/

# Reference docs dropped in working tree (canonical copies live in docs/ or the wiki)
*.docx

# Python sidecar cache
__pycache__/
*.pyc

# Coverage ledgers are a generated VIEW, regenerated on demand (SC-0068) — never committed
# (committed snapshots rot; the substance is gated live by tests/coverage-corpus.test.ts).
*-COVERAGE-LEDGER.md
